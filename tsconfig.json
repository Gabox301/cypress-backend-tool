{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    "types": ["cypress", "node", "vitest/globals"]
  },
  "include": ["cypress/**/*.ts", "src/**/*.ts", "src/**/*.svelte", "src/**/*.test.ts"],
  "exclude": ["node_modules/.svelte2tsx-language-server-files/**"]
}
